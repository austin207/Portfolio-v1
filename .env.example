# Gmail OAuth2 (for contact form)
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable Gmail API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Set redirect URI to http://localhost:3000
# 5. Use the OAuth Playground (https://developers.google.com/oauthplayground)
#    to generate a refresh token with scope: https://mail.google.com/
GMAIL_CLIENT_ID=your_client_id
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REDIRECT_URI=http://localhost:3000
GMAIL_REFRESH_TOKEN=your_refresh_token
GMAIL_SENDER=austinantony06@gmail.com
GMAIL_RECEIVER=austinantony06@gmail.com

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
